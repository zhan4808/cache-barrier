\@writefile{lot}{\contentsline {table}{\numberline {12}{\ignorespaces Measured INT4 kernel performance vs.\ cuBLAS FP16 \texttt  {torch.bmm}. ``FP16 loop'' = 128 individual \texttt  {torch.mm} calls.}}{6}{table.caption.47}\protected@file@percent }
\newlabel{tab:int4_measured}{{12}{6}{Measured INT4 kernel performance vs.\ cuBLAS FP16 \texttt {torch.bmm}. ``FP16 loop'' = 128 individual \texttt {torch.mm} calls}{table.caption.47}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces The L2 cache barrier. Roofline analysis predicts 2--3.9$\times $ INT4 speedup assuming HBM-bound operation. Measured performance shows 0.2--0.5$\times $: the INT4 kernel is \emph  {slower} than cuBLAS FP16. The 16\,MB reconstruction weight fits in H100's 50\,MB L2; after first access, weights are served from L2 at ${\sim }$12\,TB/s, making HBM savings irrelevant.}}{6}{figure.caption.48}\protected@file@percent }
\newlabel{fig:l2barrier}{{6}{6}{The L2 cache barrier. Roofline analysis predicts 2--3.9$\times $ INT4 speedup assuming HBM-bound operation. Measured performance shows 0.2--0.5$\times $: the INT4 kernel is \emph {slower} than cuBLAS FP16. The 16\,MB reconstruction weight fits in H100's 50\,MB L2; after first access, weights are served from L2 at ${\sim }$12\,TB/s, making HBM savings irrelevant}{figure.caption.48}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.5}The L2 Cache Barrier: Why Roofline Fails for Small-Matrix MLA Reconstruction}{6}{subsection.49}\protected@file@percent }
\newlabel{sec:l2barrier}{{5.5}{6}{The L2 Cache Barrier: Why Roofline Fails for Small-Matrix MLA Reconstruction}{subsection.49}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Cache-residency intervention at fixed MLA reconstruction shape (BS=1, normalized to FP16-warm). H100: FP16 rises from 1.00 to 1.34 under eviction, while INT4 rises from 1.85 to 1.62 relative to FP16-warm. A100 shows stronger asymmetry: FP16 rises from 1.00 to 1.22 while INT4 rises from 1.93 to 1.70. FP16 is 2--3$\times $ more sensitive to forced eviction than INT4, directly supporting L2-residency dependence of FP16 and dequantization-limited INT4 behavior.}}{7}{figure.caption.50}\protected@file@percent }
\newlabel{fig:cache_intervention}{{7}{7}{Cache-residency intervention at fixed MLA reconstruction shape (BS=1, normalized to FP16-warm). H100: FP16 rises from 1.00 to 1.34 under eviction, while INT4 rises from 1.85 to 1.62 relative to FP16-warm. A100 shows stronger asymmetry: FP16 rises from 1.00 to 1.22 while INT4 rises from 1.93 to 1.70. FP16 is 2--3$\times $ more sensitive to forced eviction than INT4, directly supporting L2-residency dependence of FP16 and dequantization-limited INT4 behavior}{figure.caption.50}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Weight-size scaling across the L2 boundary on H100 and A100. INT4/FP16 time ratio vs.\ FP16 weight size. Both GPUs show the same knee behavior near their L2 capacities (A100: 40\,MB, H100: 50\,MB): below the knee, INT4 is much slower; above the knee, the ratio moves toward parity as FP16 falls back to HBM. At MLA's 16\,MB operating point (arrow), both platforms remain in the L2-resident regime.}}{7}{figure.caption.51}\protected@file@percent }
\newlabel{fig:l2sweep}{{8}{7}{Weight-size scaling across the L2 boundary on H100 and A100. INT4/FP16 time ratio vs.\ FP16 weight size. Both GPUs show the same knee behavior near their L2 capacities (A100: 40\,MB, H100: 50\,MB): below the knee, INT4 is much slower; above the knee, the ratio moves toward parity as FP16 falls back to HBM. At MLA's 16\,MB operating point (arrow), both platforms remain in the L2-resident regime}{figure.caption.51}{}}
